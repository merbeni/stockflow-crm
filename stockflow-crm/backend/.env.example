DATABASE_URL=postgresql://user:password@your-server.postgres.database.azure.com:5432/stockflow
GOOGLE_API_KEY=your_google_ai_studio_api_key
SECRET_KEY=your_secret_key_for_jwt
ALGORITHM=HS256
